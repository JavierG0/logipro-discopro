# Ejemplo de archivo .env
# Copia este archivo a .env y llena los valores apropiados
# NUNCA hagas commit de .env a control de versiones

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-tu-clave-secreta-aqui-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1,tudominio.com

# Database Configuration - MariaDB
DB_ENGINE=django.db.backends.mysql
DB_NAME=discopro_db
DB_USER=root
DB_PASSWORD=tu_contraseña_mariadb
DB_HOST=127.0.0.1
DB_PORT=3306

# Para Docker, usa:
# DB_HOST=mariadb

# Security (para producción)
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# Email Configuration (opcional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para producción con Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion

# Application Settings
TIME_ZONE=America/Bogota
LANGUAGE_CODE=es-es

# AWS S3 (opcional, para archivos estáticos)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Sentry (opcional, para monitoreo de errores)
SENTRY_DSN=

# Redis (opcional, para caché)
REDIS_URL=redis://localhost:6379/0
